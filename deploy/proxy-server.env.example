# Mandatory access token for all control/tunnel HTTP requests.
CALLSIGN_ACCESS_TOKEN=replace-with-strong-random-token

# Control endpoint used by tunnel service for token validation.
CONTROL_VALIDATE_URL=http://127.0.0.1:5000/api/v1/validate

# Public WSS endpoint returned to clients during bootstrap.
CALLSIGN_TUNNEL_PUBLIC_URL=wss://overlay.example.com/connect-ws

# Keep this path consistent in control/tunnel services and reverse proxy.
CALLSIGN_TUNNEL_PATH=/connect-ws

# Tunnel mode: set to tun for real traffic forwarding; echo is debug-only.
CALLSIGN_TUN_MODE=tun

# Optional: session TTL for control service.
CALLSIGN_SESSION_TTL=3600
