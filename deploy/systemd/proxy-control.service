[Unit]
Description=Proxy Control Plane
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/callsign
EnvironmentFile=/etc/proxy-server.env
ExecStart=/opt/callsign/.venv/bin/gunicorn --workers 1 --threads 8 --timeout 60 --bind 127.0.0.1:5000 --pythonpath /opt/callsign/server/control app:app
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
